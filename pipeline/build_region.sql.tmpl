-- Build a per-region products table into an output SQLite DB from the extracted
-- intermediate parquet (see build_extract.sql.tmpl). Fast: scans the small
-- intermediate, not the 7 GB source.
-- Placeholders (substituted by build_pack.sh): __SRC__ (extracted.parquet)
--                                              __COUNTRY_TAG__ __OUT__
INSTALL sqlite;
LOAD sqlite;
ATTACH '__OUT__' AS out (TYPE SQLITE);

CREATE TABLE out.products AS
SELECT barcode, name, brand, lang, serving_label, serving_g,
       kcal100, protein100, carb100, fat100, fiber100, sugar100,
       satfat100, sodium_mg100, salt100, nutriscore
FROM read_parquet('__SRC__')
WHERE list_contains(countries_tags, '__COUNTRY_TAG__');
